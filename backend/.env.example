# backend/.env.example
# Template des variables d'environnement pour ARIA Secure
# Copiez ce fichier en .env et remplissez les valeurs

# ============================================
# DJANGO CORE
# ============================================
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-strong-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.aria-secure.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://aria-secure.com

# Environnement: development, staging, production
DJANGO_ENVIRONMENT=development

# ============================================
# BASE DE DONNÉES POSTGRESQL
# ============================================
DB_NAME=aria_db
DB_USER=aria_user
DB_PASSWORD=change_this_password
DB_HOST=localhost
DB_PORT=5432

# URL de connexion complète (optionnel)
DATABASE_URL=postgresql://aria_user:change_this_password@localhost:5432/aria_db

# ============================================
# REDIS (Cache & Celery)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_CELERY_URL=redis://localhost:6379/2

# ============================================
# STOCKAGE MINIO / S3
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=aria-secure
MINIO_USE_SSL=False

# Alternative AWS S3
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_STORAGE_BUCKET_NAME=aria-secure
# AWS_S3_REGION_NAME=eu-west-1

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ALGORITHM=RS256

# Chemins des clés RSA pour JWT (si RS256)
JWT_PRIVATE_KEY_PATH=/path/to/private.pem
JWT_PUBLIC_KEY_PATH=/path/to/public.pem

# ============================================
# MFA / 2FA CONFIGURATION
# ============================================
MFA_ISSUER_NAME=ARIA Secure
MFA_CODE_LENGTH=6
MFA_VALIDITY_WINDOW=1

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@aria-secure.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@aria-secure.com
ADMIN_EMAIL=admin@aria-secure.com

# ============================================
# AI ENGINE CONFIGURATION
# ============================================
AI_MODEL_PATH=/app/ai_models/aria_model.onnx
AI_MODEL_VERSION=v1.0.0
AI_INFERENCE_TIMEOUT_SECONDS=10
AI_MAX_BATCH_SIZE=1

# ============================================
# SENTRY (Error Tracking)
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# SECURITY
# ============================================
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-valid-fernet-key

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,https://app.aria-secure.com

# ============================================
# CELERY
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TASK_ALWAYS_EAGER=False  # True en test pour exécution synchrone

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_DIR=/var/log/aria-secure
LOG_FILE=aria_backend.log

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_MFA_ENABLED=True
FEATURE_OFFLINE_MODE=True
FEATURE_AUDIT_LOG=True
FEATURE_REPORT_SIGNATURE=True