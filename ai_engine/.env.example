# ══════════════════════════════════════════════

# ARIA Secure — AI Engine (Multi-Dataset Config)

# Projets : NIH (Thorax) & MURA (Musculosquelettique)

# ══════════════════════════════════════════════

# ── Environnement ─────────────────────────────

ENV=development  # Options: development, production

# ── Projet Actif ──────────────────────────────

# Choisir le dataset utilisé pour l'entraînement

CURRENT_PROJECT=MURA  # Options: NIH, MURA

# ── Chemins NIH (Chest X-Ray) ─────────────────

NIH_DATA_DIR=./data/NIH/images
NIH_LABELS_CSV=./data/NIH/Data_Entry_2017.csv

# ── Chemins MURA (Bone Fracture) ──────────────

MURA_DATA_DIR=./data/MURA-v1.1
MURA_TRAIN_CSV=./data/MURA-v1.1/train_labeled_studies.csv
MURA_VAL_CSV=./data/MURA-v1.1/valid_labeled_studies.csv

# ── Chemins des modèles ───────────────────────

MODELS_DIR=./models
NIH_MODEL_PATH=./models/nih_best_model.pt
MURA_MODEL_PATH=./models/mura_best_model.pt

# Export ONNX (pour déploiement IA)

MURA_ONNX_MODEL_PATH=./models/mura_aria_model.onnx
NIH_ONNX_MODEL_PATH=./models/nih_aria_model.onnx

# ── Hyperparamètres ───────────────────────────

IMAGE_SIZE=224
BATCH_SIZE=10
NUM_EPOCHS=50
LEARNING_RATE=0.0001
WEIGHT_DECAY=0.0001
NUM_WORKERS=4

# ── Spécifications du modèle ──────────────────

MODEL_NAME=efficientnet_v2_s

# ── Seuils de décision ────────────────────────

THRESHOLD=0.5
CRITICAL_THRESHOLD=0.75

# ── Device (GPU / CPU) ────────────────────────

DEVICE=auto  # Options: auto, cpu, cuda

# ── MLflow (Tracking des expériences) ─────────

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MURA_EXPERIMENT_NAME=ARIA_MURA_Bone_Anomaly
MLFLOW_NIH_EXPERIMENT_NAME=ARIA_NIH_Chest_XRay

# ── Logs ──────────────────────────────────────

LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/training.log
