# ══════════════════════════════════════════════
# ARIA Secure — .gitignore
# Python · Django · React Native · AI Engine
# ══════════════════════════════════════════════

# ── Environnements virtuels Python ────────────
venv/
env/
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Django ────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# ── Modèles IA (trop lourds pour Git) ─────────
ai_engine/models/*.pt
ai_engine/models/*.pth
ai_engine/models/*.onnx
ai_engine/models/*.bin
ai_engine/data/
mlruns/
mlartifacts/

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Tests & Coverage ──────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── React Native / Node.js ────────────────────
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/build/
mobile/android/app/debug/
mobile/android/app/release/
mobile/android/.gradle/
mobile/android/local.properties
mobile/ios/Pods/
mobile/ios/build/
mobile/*.jks
mobile/*.keystore
mobile/*.p8
mobile/*.p12
mobile/*.mobileprovision
mobile/*.orig.*

# ── Docker ────────────────────────────────────
docker/.env.production

# ── Éditeurs & OS ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Sécurité (NE JAMAIS committer) ────────────
*.pem
*.key
*.cert
*.crt
secrets/
ssl/